<%# search-bar.ejs - Recebe: search, action %>
<div class="relative w-full">
  <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline-variant">search</span>
  <form action="<%= typeof action !== 'undefined' ? action : '/browse' %>" method="GET">
    <input name="search" value="<%= typeof search !== 'undefined' ? search : '' %>" class="w-full pl-10 pr-4 py-3 bg-surface-container-low border border-outline-variant rounded-full focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none transition-colors" placeholder="Buscar aulas..." type="text">
  </form>
</div>
