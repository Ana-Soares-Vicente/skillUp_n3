<%# profile-header.ejs - Recebe: profileUser %>
<section class="bg-surface-container-lowest rounded-xl p-stack-md shadow-level-1 flex flex-col sm:flex-row items-center sm:items-start gap-gutter">
  <div class="w-24 h-24 rounded-full overflow-hidden border-4 border-surface shrink-0">
    <% if (profileUser.avatar) { %>
      <img alt="Avatar" class="w-full h-full object-cover" src="<%= profileUser.avatar %>">
    <% } else { %>
      <div class="w-full h-full bg-primary-container flex items-center justify-center text-on-primary-container text-2xl font-bold"><%= profileUser.name.substring(0,2).toUpperCase() %></div>
    <% } %>
  </div>
  <div class="flex-1 text-center sm:text-left flex flex-col justify-center h-full sm:pt-2">
    <h2 class="font-headline-md text-headline-md text-on-surface mb-1"><%= profileUser.name %></h2>
    <p class="font-body-md text-body-md text-on-surface-variant mb-4">Membro desde <%= new Date(profileUser.createdAt).getFullYear() %></p>
    <div class="flex flex-wrap gap-2 justify-center sm:justify-start">
      <span class="bg-primary/10 text-primary font-caption text-caption px-3 py-1 rounded-full"><%= profileUser.role === 'admin' ? 'Admin' : 'Aluno Pro' %></span>
    </div>
  </div>
  <div class="sm:self-center mt-4 sm:mt-0">
    <a href="/profile/settings" class="border border-outline text-on-surface hover:bg-surface-variant transition-colors rounded-lg py-2 px-4 font-label-md text-label-md">Editar Perfil</a>
  </div>
</section>
