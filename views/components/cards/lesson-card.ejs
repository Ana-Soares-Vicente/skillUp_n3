<article class="bg-surface-container-lowest rounded-xl shadow-level-1 hover:shadow-level-2 transition-all duration-300 overflow-hidden flex flex-col group cursor-pointer">
  <a href="/lessons/<%= lesson.id %>" class="block">
    <div class="h-40 w-full bg-surface-container-high relative overflow-hidden">
      <% if (lesson.thumbnail) { %>
        <img alt="<%= lesson.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="<%= lesson.thumbnail %>">
      <% } else { %>
        <div class="w-full h-full bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center">
          <span class="material-symbols-outlined text-4xl text-primary/40">play_lesson</span>
        </div>
      <% } %>
      <div class="absolute top-4 right-4 bg-surface-container-lowest/90 text-on-surface px-3 py-1 rounded-full font-caption text-caption flex items-center gap-1 backdrop-blur-sm">
        <span class="material-symbols-outlined text-[14px]">timer</span> <%= lesson.duration %> min
      </div>
      <% if (typeof progressMap !== 'undefined' && progressMap[lesson.id] && !progressMap[lesson.id].completed) { %>
        <div class="absolute top-4 left-4 bg-primary/90 text-on-primary px-3 py-1 rounded-full font-caption text-caption backdrop-blur-sm">In Progress</div>
      <% } %>
    </div>
    <div class="p-stack-md flex flex-col flex-grow">
      <% if (lesson.course && lesson.course.topic) { %>
        <span class="text-primary font-label-md text-label-md bg-primary/10 px-2 py-1 rounded self-start mb-2" style="color:<%= lesson.course.topic.color %>; background-color:<%= lesson.course.topic.color %>15"><%= lesson.course.topic.name %></span>
      <% } else if (lesson.course) { %>
        <span class="text-primary font-label-md text-label-md bg-primary/10 px-2 py-1 rounded self-start mb-2"><%= lesson.course.title %></span>
      <% } %>
      <h3 class="font-headline-sm text-[20px] leading-tight text-on-background mb-2 group-hover:text-primary transition-colors"><%= lesson.title %></h3>
      <div class="mt-auto pt-4">
        <% if (typeof progressMap !== 'undefined' && progressMap[lesson.id]) { %>
          <div class="w-full bg-surface-container-highest rounded-full h-2 mb-2">
            <div class="bg-secondary h-2 rounded-full" style="width:<%= progressMap[lesson.id].completed ? 100 : Math.min((progressMap[lesson.id].watchedMinutes / lesson.duration) * 100, 95) %>%"></div>
          </div>
        <% } %>
        <% if (lesson.author) { %>
          <div class="flex items-center gap-2">
            <% if (lesson.author.avatar) { %>
              <img alt="<%= lesson.author.name %>" class="w-6 h-6 rounded-full border border-outline-variant object-cover" src="<%= lesson.author.avatar %>">
            <% } else { %>
              <div class="w-6 h-6 rounded-full bg-surface-variant flex items-center justify-center text-on-surface-variant font-caption text-[10px]"><%= lesson.author.name.substring(0,2).toUpperCase() %></div>
            <% } %>
            <span class="font-caption text-caption text-on-surface-variant"><%= lesson.author.name %></span>
          </div>
        <% } %>
      </div>
    </div>
  </a>
</article>
