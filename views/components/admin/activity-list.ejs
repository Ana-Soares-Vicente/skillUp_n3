<%# activity-list.ejs - Recebe: recentActivity %>
<section class="bg-surface-container-lowest rounded-lg shadow-level-1 border border-surface-variant overflow-hidden">
  <div class="px-stack-md py-4 border-b border-surface-variant flex justify-between items-center bg-surface-container-low/50">
    <h3 class="font-headline-sm text-xl text-on-surface">Atividade Recente</h3>
  </div>
  <div class="divide-y divide-surface-variant">
    <% if (recentActivity && recentActivity.length > 0) { %>
      <% recentActivity.forEach(activity => { %>
        <div class="px-stack-md py-4 flex items-center gap-4 hover:bg-surface-container/30 transition-colors">
          <% if (activity.user && activity.user.avatar) { %>
            <img alt="<%= activity.user.name %>" class="w-10 h-10 rounded-full object-cover flex-shrink-0" src="<%= activity.user.avatar %>">
          <% } else { %>
            <div class="w-10 h-10 rounded-full bg-surface-variant flex-shrink-0 flex items-center justify-center font-label-md text-xs font-bold"><%= activity.user ? activity.user.name.substring(0,2).toUpperCase() : '??' %></div>
          <% } %>
          <div class="flex-1">
            <p class="font-body-md text-body-md text-on-surface">
              <span class="font-label-md text-label-md"><%= activity.user ? activity.user.name : 'Usuário' %></span>
              concluiu <span class="font-label-md text-label-md text-primary"><%= activity.lesson ? activity.lesson.title : 'uma aula' %></span>
            </p>
            <p class="font-caption text-caption text-on-surface-variant"><%= activity.completedAt ? new Date(activity.completedAt).toLocaleString() : '' %></p>
          </div>
          <span class="inline-flex items-center px-2 py-1 rounded-full bg-secondary-container/20 text-on-secondary-container font-caption text-caption hidden sm:block">Concluído</span>
        </div>
      <% }); %>
    <% } else { %>
      <p class="px-stack-md py-8 text-center text-on-surface-variant">Nenhuma atividade recente</p>
    <% } %>
  </div>
</section>
