<%# trending-lessons.ejs - Recebe: trendingLessons %>
<div class="bg-surface-container-lowest rounded-lg p-stack-md shadow-level-1 border border-surface-variant">
  <h3 class="font-headline-sm text-xl text-on-surface mb-4">Aulas em Alta</h3>
  <div class="space-y-4">
    <% if (trendingLessons && trendingLessons.length > 0) { %>
      <% trendingLessons.forEach(lesson => { %>
        <div class="flex items-start gap-3 p-2 hover:bg-surface-container-low rounded transition-colors cursor-pointer group">
          <div class="w-12 h-12 rounded bg-primary-container/20 flex-shrink-0 flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-on-primary transition-colors">
            <span class="material-symbols-outlined"><%= lesson.course && lesson.course.topic ? lesson.course.topic.icon : 'play_circle' %></span>
          </div>
          <div class="flex-1 min-w-0">
            <h4 class="font-label-md text-label-md text-on-surface truncate"><%= lesson.title %></h4>
            <p class="font-caption text-caption text-on-surface-variant"><%= lesson.progress ? lesson.progress.length : 0 %> alunos ativos</p>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <p class="text-on-surface-variant text-center py-4">Nenhuma aula em alta</p>
    <% } %>
  </div>
</div>
