<%# lesson-sidebar.ejs - Recebe: lesson, curriculum, curriculumProgress, completedCount %>
<aside class="w-full lg:w-80 xl:w-96 bg-surface-container-lowest lg:border-l border-t lg:border-t-0 border-outline-variant/30 flex flex-col lg:h-full shrink-0">
  <div class="p-gutter border-b border-outline-variant/30">
    <h2 class="font-headline-sm text-headline-sm text-on-surface mb-2"><%= lesson.course ? lesson.course.title : 'Aulas Avulsas' %></h2>
    <div class="flex justify-between items-center mb-2">
      <span class="font-caption text-caption text-outline">Progresso do Curso</span>
      <span class="font-label-md text-label-md text-secondary"><%= completedCount %>/<%= curriculum.length %> Aulas</span>
    </div>
    <div class="h-2 w-full bg-surface-variant rounded-full overflow-hidden">
      <div class="h-full bg-secondary-fixed-dim rounded-full" style="width:<%= curriculum.length > 0 ? (completedCount / curriculum.length * 100) : 0 %>%"></div>
    </div>
  </div>
  <div class="flex-1 overflow-y-auto p-4 space-y-2">
    <% curriculum.forEach((item, idx) => {
      const isActive = item.id == lesson.id;
      const isCompleted = curriculumProgress[item.id] && curriculumProgress[item.id].completed;
    %>
      <% if (isActive) { %>
        <div class="block p-3 rounded-lg bg-primary-container/10 border border-primary/20 relative">
          <div class="absolute left-0 top-0 bottom-0 w-1 bg-primary rounded-l-lg"></div>
          <div class="flex items-start gap-3 pl-2">
            <div class="w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center shrink-0 mt-0.5">
              <span class="material-symbols-outlined text-primary text-[16px]">play_arrow</span>
            </div>
            <div>
              <p class="font-label-md text-label-md text-primary font-bold"><%= idx + 1 %>. <%= item.title %></p>
              <p class="font-caption text-caption text-primary/80 flex items-center gap-1 mt-1">
                <span class="material-symbols-outlined text-[14px]">schedule</span> <%= item.duration %> min • Reproduzindo
              </p>
            </div>
          </div>
        </div>
      <% } else { %>
        <a class="block p-3 rounded-lg hover:bg-surface-container-low transition-colors group" href="/lessons/<%= item.id %>">
          <div class="flex items-start gap-3 <%= !isCompleted ? 'opacity-60' : '' %>">
            <div class="w-6 h-6 rounded-full <%= isCompleted ? 'bg-secondary/10' : 'border-2 border-outline-variant' %> flex items-center justify-center shrink-0 mt-0.5">
              <% if (isCompleted) { %>
                <span class="material-symbols-outlined text-secondary text-[16px]" style="font-variation-settings:'FILL' 1">check_circle</span>
              <% } else { %>
                <span class="font-caption text-caption text-outline-variant"><%= idx + 1 %></span>
              <% } %>
            </div>
            <div>
              <p class="font-label-md text-label-md text-on-surface"><%= idx + 1 %>. <%= item.title %></p>
              <p class="font-caption text-caption text-outline flex items-center gap-1 mt-1">
                <span class="material-symbols-outlined text-[14px]"><%= isCompleted ? 'play_circle' : 'lock' %></span> <%= item.duration %> min
              </p>
            </div>
          </div>
        </a>
      <% } %>
    <% }); %>
  </div>
</aside>
