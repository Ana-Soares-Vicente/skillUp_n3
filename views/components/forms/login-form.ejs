<form action="/auth/login" method="POST" class="bg-surface-container-lowest p-8 rounded-2xl shadow-level-2 border border-outline-variant/30">
  <h2 class="font-headline-md text-headline-md text-on-surface text-center mb-2">Bem-vindo de volta</h2>
  <p class="text-on-surface-variant text-center mb-8">Insira suas credenciais para continuar</p>
  <div class="space-y-4">
    <div>
      <label class="font-label-md text-label-md text-on-surface mb-1 block">E-mail</label>
      <div class="relative">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-lg">mail</span>
        <input type="email" name="email" required class="w-full pl-10 pr-4 py-3 border border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface text-on-surface" placeholder="you@example.com">
      </div>
    </div>
    <div>
      <label class="font-label-md text-label-md text-on-surface mb-1 block">Senha</label>
      <div class="relative">
        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-lg">lock</span>
        <input type="password" name="password" required class="w-full pl-10 pr-4 py-3 border border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface text-on-surface" placeholder="••••••••">
      </div>
    </div>
    <button type="submit" class="w-full bg-primary text-on-primary py-3 rounded-lg font-label-md text-label-md hover:bg-blue-700 transition-colors shadow-sm mt-2">
      <i class="fas fa-sign-in-alt mr-2"></i>Entrar
    </button>
  </div>
  <p class="text-center text-on-surface-variant mt-6 text-sm">
    Não tem uma conta? <a href="/auth/register" class="text-primary hover:underline font-semibold">Cadastre-se</a>
  </p>
</form>
