      <button id="mobile-menu-btn" class="md:hidden text-gray-600 dark:text-gray-400 hover:text-blue-500 hover:bg-gray-50 dark:hover:bg-gray-900 transition-all duration-200 p-2 rounded-full ml-1">
        <span class="material-symbols-outlined">menu</span>
      </button>
