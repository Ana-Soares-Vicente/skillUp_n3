        <a href="/auth/logout" class="text-gray-500 hover:text-red-500 transition-colors px-2 py-1 text-sm">Sair</a>
      <% } else { %>
        <a href="/auth/login" class="text-gray-600 hover:text-blue-500 transition-colors px-2 py-1 text-sm">Entrar</a>
        <a href="/auth/register" class="bg-primary text-on-primary px-4 py-2 rounded-lg font-label-md text-label-md hover:bg-primary-container hover:text-on-primary-container transition-colors ml-2 shadow-sm">Começar</a>
