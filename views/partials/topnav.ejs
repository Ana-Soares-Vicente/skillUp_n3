<nav class="bg-white/90 dark:bg-gray-950/90 backdrop-blur-md font-label text-sm font-medium tracking-tight fixed top-0 w-full z-50 shadow-sm dark:shadow-none border-b border-gray-100 dark:border-gray-800">
