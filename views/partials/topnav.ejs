  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 dark:border-gray-800 bg-white/95 dark:bg-gray-950/95 backdrop-blur-md px-6 py-6 space-y-6 shadow-lg absolute w-full left-0 top-16 max-h-[calc(100vh-4rem)] overflow-y-auto z-40">
