<%# Course Detail - Detalhes do Curso %>
  <div class="w-full">
    <!-- Hero Section -->
    <div class="relative bg-inverse-surface text-on-primary w-full py-16 md:py-24 overflow-hidden">
      <% if (course.thumbnail) { %>
        <div class="absolute inset-0">
          <img src="<%= course.thumbnail %>" alt="" class="w-full h-full object-cover opacity-30">
          <div class="absolute inset-0 bg-gradient-to-r from-inverse-surface via-inverse-surface/80 to-transparent">
          </div>
        </div>
        <% } %>

          <div
            class="max-w-container-max-width mx-auto px-gutter relative z-10 flex flex-col md:flex-row gap-8 items-start">
            <div class="flex-1 space-y-4">
              <% if (course.topic) { %>
                <span class="inline-block px-3 py-1 rounded-full text-sm font-medium"
                  style="background-color: <%= course.topic.color %>; color: white;">
                  <%= course.topic.name %>
                </span>
                <% } %>

                  <h1 class="font-display-lg text-display-lg">
                    <%= course.title %>
                  </h1>

                  <div class="flex flex-wrap items-center gap-4 text-sm opacity-90 mt-2">
                    <% let totalDuration=0; if (topicLessons && topicLessons.length> 0) {
                      totalDuration = topicLessons.reduce((acc, curr) => acc + (curr.duration || 0), 0);
                      }
                      const hours = Math.floor(totalDuration / 60);
                      const minutes = totalDuration % 60;
                      const durationText = hours > 0 ? `${hours}h ${minutes}m` : `${totalDuration}m`;
                      %>
                      <span class="flex items-center gap-1"><span
                          class="material-symbols-outlined text-[18px]">play_lesson</span>
                        <%= lessonCount %> aulas
                      </span>
                      <span class="flex items-center gap-1"><span
                          class="material-symbols-outlined text-[18px]">schedule</span>
                        <%= durationText %>
                      </span>
                      <span class="flex items-center gap-1 capitalize"><span
                          class="material-symbols-outlined text-[18px]">school</span>
                        <%= course.level==='beginner' ? 'Iniciante' : course.level==='intermediate' ? 'Intermediário'
                          : 'Avançado' %>
                      </span>
                  </div>

                  <% if (course.description) { %>
                    <p class="font-body-lg text-body-lg max-w-3xl mt-6 opacity-90 leading-relaxed">
                      <%= course.description %>
                    </p>
                    <% } %>
            </div>

            <!-- Action Card -->
            <div class="w-full md:w-80 bg-surface text-on-surface rounded-xl p-6 shadow-level-2 mt-8 md:mt-0">
              <% if (isEnrolled) { %>
                <div class="text-center mb-4">
                  <div
                    class="inline-flex items-center justify-center w-12 h-12 bg-secondary/10 text-secondary rounded-full mb-3">
                    <span class="material-symbols-outlined text-2xl">check_circle</span>
                  </div>
                  <h3 class="font-headline-sm text-headline-sm">Você está inscrito!</h3>
                </div>
                <a href="/profile/course/<%= course.id %>"
                  class="block w-full text-center bg-primary text-on-primary py-3 rounded-lg font-label-md text-label-md hover:bg-primary-container hover:text-on-primary-container transition-colors shadow-sm mb-3">
                  Ir para a Trilha
                </a>
                <% if (course.exam) { %>
                  <% if (typeof isCourseCompleted !== 'undefined' && isCourseCompleted) { %>
                  <a href="/browse/<%= course.id %>/prova"
                    class="block w-full text-center border border-primary text-primary py-3 rounded-lg font-label-md text-label-md hover:bg-primary/5 transition-colors mb-3">
                    <span class="material-symbols-outlined align-middle text-sm mr-1">assignment</span> Fazer Prova Final
                  </a>
                  <% } else { %>
                  <div class="block w-full text-center border border-outline-variant text-outline-variant py-3 rounded-lg font-label-md text-label-md mb-3 opacity-70 cursor-not-allowed" title="Conclua todas as aulas para liberar a prova">
                    <span class="material-symbols-outlined align-middle text-sm mr-1">lock</span> Fazer Prova Final
                  </div>
                  <% } %>
                <% } %>
                    <form action="/browse/<%= course.id %>/unenroll" method="POST" class="text-center">
                      <button type="submit"
                        class="text-error hover:text-error-container text-sm font-medium transition-colors"
                        onclick="return confirm('Tem certeza que deseja cancelar sua inscrição? Seu progresso será mantido, mas o curso não aparecerá mais no seu perfil.')">
                        Cancelar inscrição
                      </button>
                    </form>
                    <% } else { %>
                      <form action="/browse/<%= course.id %>/enroll" method="POST">
                        <button type="submit"
                          class="w-full bg-primary text-on-primary py-3 rounded-lg font-label-md text-label-md hover:bg-primary-container hover:text-on-primary-container transition-colors shadow-sm mb-3">
                          Inscrever-se neste Curso
                        </button>
                      </form>
                      <p class="text-xs text-center text-outline-variant">Acesso ilimitado e gratuito.</p>
                      <% } %>
            </div>
          </div>
    </div>

    <!-- Curriculum Section -->
    <div class="max-w-container-max-width mx-auto px-gutter py-12">
      <h2 class="font-headline-md text-headline-md mb-6">Conteúdo do Curso</h2>

      <% if (topicLessons && topicLessons.length> 0) { %>
        <div
          class="bg-surface-container-lowest rounded-xl shadow-level-1 overflow-hidden border border-outline-variant/20">
          <% topicLessons.forEach((lesson, idx)=> { %>
            <% 
              const isLast = idx === topicLessons.length - 1; 
              const isCompleted = typeof userProgress !== 'undefined' && userProgress[lesson.id];
              const bgClass = isCompleted ? 'bg-secondary/10 hover:bg-secondary/20' : 'hover:bg-surface-container-low';
              const borderClass = !isLast ? 'border-b border-outline-variant/20' : '';
            %>
              <div
                class="flex items-center gap-4 p-4 <%= borderClass %> <%= bgClass %> transition-colors">
                <div
                  class="w-8 h-8 rounded-full <%= isCompleted ? 'bg-secondary text-on-secondary' : 'bg-primary/10 text-primary' %> flex items-center justify-center font-label-md text-sm shrink-0">
                  <% if (isCompleted) { %>
                    <span class="material-symbols-outlined text-[16px]">check</span>
                  <% } else { %>
                    <%= lesson.order || (idx + 1) %>
                  <% } %>
                </div>

                <div class="flex-grow min-w-0">
                  <h4 class="font-label-md text-label-md <%= isCompleted ? 'text-secondary' : 'text-on-surface' %> truncate">
                    <%= lesson.title %>
                  </h4>
                </div>

                <div class="text-outline font-caption text-sm flex items-center gap-1 shrink-0">
                  <span class="material-symbols-outlined text-[16px]">schedule</span>
                  <%= lesson.duration %> min
                </div>

                <% if (isEnrolled) { %>
                  <a href="/lessons/<%= lesson.id %>"
                    class="shrink-0 ml-4 p-2 text-primary hover:bg-primary/10 rounded-full transition-colors"
                    title="Assistir aula">
                    <span class="material-symbols-outlined">play_circle</span>
                  </a>
                  <% } else { %>
                    <span class="shrink-0 ml-4 p-2 text-outline-variant" title="Inscreva-se para assistir">
                      <span class="material-symbols-outlined">lock</span>
                    </span>
                    <% } %>
              </div>
              <% }); %>
        </div>
        <% } else { %>
          <p class="text-on-surface-variant">Nenhuma aula disponível neste curso ainda.</p>
          <% } %>
    </div>
  </div>