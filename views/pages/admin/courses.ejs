<%# Admin - Courses Management %>
<div class="flex flex-col gap-stack-lg">
  <div class="flex justify-between items-center bg-surface-container-lowest p-stack-md rounded-xl shadow-level-1">
    <div>
      <h1 class="font-headline-md text-headline-md text-on-surface">Cursos</h1>
      <p class="font-body-md text-body-md text-on-surface-variant mt-1">Gerenciar cursos da plataforma</p>
    </div>
    <a href="/admin/cursos/criar" class="flex items-center gap-2 bg-primary text-on-primary rounded-lg py-2 px-4 font-label-md text-label-md shadow-level-1">
      <span class="material-symbols-outlined text-sm">add</span> Novo Curso
    </a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
    <% if (courses && courses.length > 0) { %>
      <% courses.forEach(course => { %>
        <div class="bg-surface-container-lowest rounded-xl p-stack-md shadow-level-1 border border-outline-variant/30 hover:shadow-level-2 transition-all duration-300 group flex flex-col">
          <% if (course.thumbnail) { %>
            <img src="<%= course.thumbnail %>" alt="<%= course.title %>" class="w-full h-40 object-cover rounded-lg mb-4">
          <% } else { %>
            <div class="w-full h-40 bg-surface-variant rounded-lg mb-4 flex items-center justify-center">
              <span class="material-symbols-outlined text-4xl text-outline">school</span>
            </div>
          <% } %>
          
          <div class="flex-1 min-w-0">
            <h3 class="font-headline-sm text-lg text-on-surface line-clamp-2"><%= course.title %></h3>
            <p class="font-caption text-caption text-on-surface-variant mt-1">
              Status: 
              <span class="<%= course.status === 'published' ? 'text-green-600' : 'text-orange-500' %>">
                <%= course.status === 'published' ? 'Publicado' : 'Rascunho' %>
              </span>
            </p>
            <p class="font-caption text-caption text-on-surface-variant mt-1">Nível: <%= course.level %></p>
          </div>
          
          <div class="flex flex-col gap-2 pt-4 mt-4 border-t border-outline-variant/20">
            <div class="flex gap-2">
              <a href="/admin/cursos/<%= course.id %>/editar" class="flex-1 text-center py-2 rounded-lg text-primary bg-primary/5 hover:bg-primary/10 font-label-md text-label-md transition-colors">
                Editar
              </a>
              <form action="/admin/cursos/<%= course.id %>/excluir" method="POST" class="flex-1" onsubmit="return confirm('Excluir este curso?')">
                <button type="submit" class="w-full py-2 rounded-lg text-error bg-error/5 hover:bg-error/10 font-label-md text-label-md transition-colors">
                  Excluir
                </button>
              </form>
            </div>
            <a href="/admin/cursos/<%= course.id %>/prova" class="w-full text-center py-2 rounded-lg text-secondary bg-secondary/5 hover:bg-secondary/10 font-label-md text-label-md transition-colors border border-secondary/20">
              <span class="material-symbols-outlined text-sm align-middle mr-1">assignment</span> Gerenciar Prova
            </a>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <div class="col-span-full text-center py-16">
        <span class="material-symbols-outlined text-6xl text-outline-variant mb-4">school</span>
        <p class="font-headline-sm text-headline-sm text-on-surface-variant">Nenhum curso cadastrado</p>
        <p class="text-on-surface-variant mt-2">Crie seu primeiro curso para começar a adicionar aulas.</p>
      </div>
    <% } %>
  </div>
</div>
