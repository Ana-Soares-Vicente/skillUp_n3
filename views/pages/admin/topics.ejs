<%# Admin - Topics Management %>
<div class="flex flex-col gap-stack-lg">
  <div class="flex justify-between items-center bg-surface-container-lowest p-stack-md rounded-xl shadow-level-1">
    <div>
      <h1 class="font-headline-md text-headline-md text-on-surface">Tópicos</h1>
      <p class="font-body-md text-body-md text-on-surface-variant mt-1">Gerenciar categorias de aprendizado</p>
    </div>
    <a href="/admin/topicos/criar" class="flex items-center gap-2 bg-primary text-on-primary rounded-lg py-2 px-4 font-label-md text-label-md shadow-level-1">
      <span class="material-symbols-outlined text-sm">add</span> Novo Tópico
    </a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
    <% if (topics && topics.length > 0) { %>
      <% topics.forEach(topic => { %>
        <div class="bg-surface-container-lowest rounded-xl p-stack-md shadow-level-1 border border-outline-variant/30 hover:shadow-level-2 transition-all duration-300 group">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center" data-bg="<%= topic.color %>" data-bg-alpha="20">
              <span class="material-symbols-outlined text-2xl" data-color="<%= topic.color %>"><%= topic.icon %></span>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-headline-sm text-lg text-on-surface truncate"><%= topic.name %></h3>
              <p class="font-caption text-caption text-on-surface-variant">/<%= topic.slug %></p>
            </div>
            <div class="w-3 h-3 rounded-full border-2" data-bg="<%= topic.color %>" data-border="<%= topic.color %>"></div>
          </div>
          <div class="flex items-center gap-4 mb-4 text-on-surface-variant">
            <% 
              let totalLessons = 0;
              if (topic.courses) {
                topic.courses.forEach(c => {
                  if (c.lessons) totalLessons += c.lessons.length;
                });
              }
            %>
            <span class="font-caption text-caption flex items-center gap-1">
              <span class="material-symbols-outlined text-sm">menu_book</span>
              <%= totalLessons %> aulas
            </span>
            <span class="font-caption text-caption flex items-center gap-1">
              <span class="material-symbols-outlined text-sm">folder</span>
              <%= topic.courses ? topic.courses.length : 0 %> cursos
            </span>
          </div>
          <div class="flex gap-2 pt-4 border-t border-outline-variant/20">
            <a href="/admin/topicos/<%= topic.id %>/editar" class="flex-1 text-center py-2 rounded-lg text-primary bg-primary/5 hover:bg-primary/10 font-label-md text-label-md transition-colors">
              Editar
            </a>
            <form action="/admin/topicos/<%= topic.id %>/excluir" method="POST" class="flex-1" onsubmit="return confirm('Excluir este topico?')">
              <button type="submit" class="w-full py-2 rounded-lg text-error bg-error/5 hover:bg-error/10 font-label-md text-label-md transition-colors">
                Excluir
              </button>
            </form>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <div class="col-span-full text-center py-16">
        <span class="material-symbols-outlined text-6xl text-outline-variant mb-4">category</span>
        <p class="font-headline-sm text-headline-sm text-on-surface-variant">Nenhum tópico ainda</p>
        <p class="text-on-surface-variant mt-2">Crie seu primeiro tópico para organizar os cursos.</p>
      </div>
    <% } %>
  </div>
</div>

<script>
  document.querySelectorAll('[data-bg]').forEach(el => {
    const color = el.dataset.bg;
    const alpha = el.dataset.bgAlpha || '';
    el.style.backgroundColor = color + alpha;
  });
  document.querySelectorAll('[data-color]').forEach(el => {
    el.style.color = el.dataset.color;
  });
  document.querySelectorAll('[data-border]').forEach(el => {
    el.style.borderColor = el.dataset.border;
  });
</script>
