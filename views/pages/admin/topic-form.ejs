<%# Topic Create/Edit Form %>
<div class="max-w-2xl mx-auto space-y-stack-lg">
  <h1 class="font-headline-md text-headline-md text-on-surface"><%= topic ? 'Editar Tópico' : 'Novo Tópico' %></h1>
  <form action="<%= topic ? '/admin/topicos/' + topic.id : '/admin/topicos' %>" method="POST" class="bg-surface-container-lowest rounded-xl p-stack-md shadow-level-1 space-y-6">
    <div>
      <label class="font-label-md text-label-md text-on-surface mb-1 block">Nome *</label>
      <input type="text" name="name" value="<%= topic ? topic.name : '' %>" required class="w-full px-4 py-3 border border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface" placeholder="e.g. Technology">
    </div>
    <div>
      <label class="font-label-md text-label-md text-on-surface mb-1 block">URL Amigável *</label>
      <input type="text" name="slug" value="<%= topic ? topic.slug : '' %>" required class="w-full px-4 py-3 border border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface" placeholder="e.g. tech">
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="font-label-md text-label-md text-on-surface mb-1 block">Cor</label>
        <div class="flex items-center gap-3">
          <input type="color" name="color" value="<%= topic ? topic.color : '#0050cb' %>" class="w-12 h-12 rounded-lg border border-outline-variant cursor-pointer">
          <input type="text" value="<%= topic ? topic.color : '#0050cb' %>" class="flex-1 px-4 py-3 border border-outline-variant rounded-lg bg-surface font-caption" readonly id="colorText">
        </div>
      </div>
      <div>
        <label class="font-label-md text-label-md text-on-surface mb-1 block">Ícone (Material Symbols)</label>
        <div class="flex items-center gap-3">
          <select name="icon" id="iconSelect" class="flex-1 px-4 py-3 border border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface appearance-none cursor-pointer">
            <% const icons = ['school', 'code', 'design_services', 'science', 'language', 'business', 'psychology', 'terminal', 'brush', 'build', 'monitoring', 'menu_book', 'campaign', 'fitness_center', 'health_and_safety', 'public', 'history_edu', 'calculate']; %>
            <% const currentIcon = topic ? topic.icon : 'school'; %>
            <% icons.forEach(icon => { %>
              <option value="<%= icon %>" <%= currentIcon === icon ? 'selected' : '' %>><%= icon %></option>
            <% }); %>
          </select>
          <div class="w-12 h-12 flex items-center justify-center border border-outline-variant rounded-lg bg-surface-container">
            <span class="material-symbols-outlined text-2xl text-on-surface" id="iconPreview"><%= currentIcon %></span>
          </div>
        </div>
      </div>
    </div>
    <div class="flex gap-4 pt-4">
      <button type="submit" class="bg-primary text-on-primary px-6 py-3 rounded-lg font-label-md text-label-md hover:bg-blue-700 transition-colors shadow-sm">
        <%= topic ? 'Atualizar Tópico' : 'Criar Tópico' %>
      </button>
      <a href="/admin/topicos" class="border border-outline-variant text-on-surface px-6 py-3 rounded-lg font-label-md text-label-md hover:bg-surface-variant transition-colors">
        Cancelar
      </a>
    </div>
  </form>
</div>
<script>
  document.querySelector('input[name="color"]').addEventListener('input', function(e) {
    document.getElementById('colorText').value = e.target.value;
  });
  
  document.getElementById('iconSelect').addEventListener('change', function(e) {
    document.getElementById('iconPreview').textContent = e.target.value;
  });
</script>
