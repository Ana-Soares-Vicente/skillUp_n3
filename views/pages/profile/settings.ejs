<%# Settings Page %>
<div class="w-full max-w-2xl mx-auto px-gutter py-stack-lg space-y-stack-lg">
  <h1 class="font-headline-md text-headline-md text-on-surface">Configurações</h1>
  <form action="/profile/settings" method="POST" enctype="multipart/form-data" class="bg-surface-container-lowest rounded-xl p-stack-md shadow-level-1 space-y-6">
    <div class="flex items-center gap-6 pb-6 border-b border-outline-variant/30">
      <div class="w-20 h-20 rounded-full overflow-hidden border-4 border-surface shrink-0">
        <% if (profileUser.avatar) { %>
          <img src="<%= profileUser.avatar %>" alt="Avatar" class="w-full h-full object-cover">
        <% } else { %>
          <div class="w-full h-full bg-primary-container flex items-center justify-center text-on-primary-container text-xl font-bold"><%= profileUser.name.substring(0,2).toUpperCase() %></div>
        <% } %>
      </div>
      <div>
        <label class="font-label-md text-label-md text-on-surface mb-1 block">Avatar</label>
        <input type="file" name="avatar" accept="image/*" class="text-sm">
      </div>
    </div>
    <div>
      <label class="font-label-md text-label-md text-on-surface mb-1 block">Nome</label>
      <input type="text" name="name" value="<%= profileUser.name %>" class="w-full px-4 py-3 border border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface">
    </div>
    <div>
      <label class="font-label-md text-label-md text-on-surface mb-1 block">E-mail</label>
      <input type="email" name="email" value="<%= profileUser.email %>" class="w-full px-4 py-3 border border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface">
    </div>
    <div>
      <label class="font-label-md text-label-md text-on-surface mb-1 block">Biografia</label>
      <textarea name="bio" rows="3" maxlength="500" class="w-full px-4 py-3 border border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface"><%= profileUser.bio || '' %></textarea>
    </div>
    <div class="pt-6 border-t border-outline-variant/30">
      <h3 class="font-headline-sm text-lg text-on-surface mb-4">Mudar Senha</h3>
      <div class="space-y-4">
        <div>
          <label class="font-label-md text-label-md text-on-surface mb-1 block">Senha Atual</label>
          <input type="password" name="currentPassword" class="w-full px-4 py-3 border border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface">
        </div>
        <div>
          <label class="font-label-md text-label-md text-on-surface mb-1 block">Nova Senha</label>
          <input type="password" name="newPassword" minlength="6" class="w-full px-4 py-3 border border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface">
        </div>
      </div>
    </div>
    <button type="submit" class="bg-primary text-on-primary px-6 py-3 rounded-lg font-label-md text-label-md hover:bg-blue-700 transition-colors shadow-sm">
      <i class="fas fa-save mr-2"></i>Salvar Alterações
    </button>
  </form>

  <form action="/profile/cadastro-complementar" method="POST" class="bg-surface-container-lowest rounded-xl p-stack-md shadow-level-1 space-y-6 mt-8">
    <div class="border-b border-outline-variant/30 pb-4 mb-4">
      <h3 class="font-headline-sm text-lg text-on-surface">Cadastro Complementar</h3>
      <p class="text-sm text-slate-500">Informações adicionais e endereço.</p>
    </div>
    
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="font-label-md text-label-md text-on-surface mb-1 block">Telefone</label>
        <input type="text" id="telefone" name="telefone" value="<%= profileUser.telefone || '' %>" placeholder="(00) 00000-0000" maxlength="15" class="w-full px-4 py-3 border border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface">
      </div>
      <div>
        <label class="font-label-md text-label-md text-on-surface mb-1 block">Gênero</label>
        <select name="genero" class="w-full px-4 py-3 border border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface">
          <option value="">Selecione...</option>
          <option value="Masculino" <%= profileUser.genero === 'Masculino' ? 'selected' : '' %>>Masculino</option>
          <option value="Feminino" <%= profileUser.genero === 'Feminino' ? 'selected' : '' %>>Feminino</option>
          <option value="Outro" <%= profileUser.genero === 'Outro' ? 'selected' : '' %>>Outro</option>
        </select>
      </div>
    </div>

    <div class="grid grid-cols-12 gap-4">
      <div class="col-span-5">
        <div class="flex justify-between items-end mb-1">
            <label class="font-label-md text-label-md text-on-surface block">CEP</label>
            <button type="button" onclick="openCepModal()" class="text-xs bg-blue-100 text-blue-700 px-2 py-1 rounded-md font-semibold hover:bg-blue-200 transition-colors shadow-sm flex items-center gap-1">
                <i class="fas fa-question-circle"></i> Não sei meu CEP
            </button>
        </div>
        <div class="flex">
            <input type="text" id="cep" name="cep" value="<%= profileUser.cep || '' %>" placeholder="00000-000" class="w-full px-4 py-3 border border-outline-variant rounded-l-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface">
            <button type="button" onclick="buscarCep()" class="bg-slate-200 px-4 rounded-r-lg hover:bg-slate-300 transition-colors border border-l-0 border-outline-variant"><i class="fas fa-search text-slate-600"></i></button>
        </div>
      </div>
      <div class="col-span-7">
        <label class="font-label-md text-label-md text-on-surface mb-1 block">Rua</label>
        <input type="text" id="rua" name="rua" value="<%= profileUser.rua || '' %>" class="w-full px-4 py-3 border border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface bg-slate-50" readonly>
      </div>
    </div>
    
    <div class="grid grid-cols-12 gap-4">
      <div class="col-span-5">
        <label class="font-label-md text-label-md text-on-surface mb-1 block">Bairro</label>
        <input type="text" id="bairro" name="bairro" value="<%= profileUser.bairro || '' %>" class="w-full px-4 py-3 border border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface bg-slate-50" readonly>
      </div>
      <div class="col-span-5">
        <label class="font-label-md text-label-md text-on-surface mb-1 block">Cidade</label>
        <input type="text" id="cidade" name="cidade" value="<%= profileUser.cidade || '' %>" class="w-full px-4 py-3 border border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface bg-slate-50" readonly>
      </div>
      <div class="col-span-2">
        <label class="font-label-md text-label-md text-on-surface mb-1 block">UF</label>
        <input type="text" id="estado" name="estado" value="<%= profileUser.estado || '' %>" class="w-full px-4 py-3 border border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface bg-slate-50" readonly>
      </div>
    </div>

    <div>
        <label class="font-label-md text-label-md text-on-surface mb-1 block">Complemento</label>
        <input type="text" id="complemento" name="complemento" value="<%= profileUser.complemento || '' %>" class="w-full px-4 py-3 border border-outline-variant rounded-lg focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none bg-surface">
    </div>

    <button type="submit" class="bg-primary text-on-primary px-6 py-3 rounded-lg font-label-md text-label-md hover:bg-blue-700 transition-colors shadow-sm">
      <i class="fas fa-save mr-2"></i>Salvar Cadastro
    </button>
  </form>

</div>

<!-- Modal Buscar CEP -->
<div id="cepModal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center">
    <div class="bg-white rounded-xl p-6 w-full max-w-lg shadow-xl relative">
        <button type="button" onclick="closeCepModal()" class="absolute top-4 right-4 text-slate-400 hover:text-slate-600"><i class="fas fa-times text-xl"></i></button>
        <h3 class="font-bold text-xl mb-4 text-slate-800">Buscar CEP por Endereço</h3>
        
        <div class="space-y-4">
            <div class="grid grid-cols-4 gap-4">
                <div class="col-span-1">
                    <label class="block text-sm mb-1 text-slate-600">UF</label>
                    <select id="modalUf" class="w-full border rounded p-2 focus:border-blue-500 outline-none bg-white">
                        <option value="">UF</option>
                        <option value="AC">AC</option>
                        <option value="AL">AL</option>
                        <option value="AP">AP</option>
                        <option value="AM">AM</option>
                        <option value="BA">BA</option>
                        <option value="CE">CE</option>
                        <option value="DF">DF</option>
                        <option value="ES">ES</option>
                        <option value="GO">GO</option>
                        <option value="MA">MA</option>
                        <option value="MT">MT</option>
                        <option value="MS">MS</option>
                        <option value="MG">MG</option>
                        <option value="PA">PA</option>
                        <option value="PB">PB</option>
                        <option value="PR">PR</option>
                        <option value="PE">PE</option>
                        <option value="PI">PI</option>
                        <option value="RJ">RJ</option>
                        <option value="RN">RN</option>
                        <option value="RS">RS</option>
                        <option value="RO">RO</option>
                        <option value="RR">RR</option>
                        <option value="SC">SC</option>
                        <option value="SP">SP</option>
                        <option value="SE">SE</option>
                        <option value="TO">TO</option>
                    </select>
                </div>
                <div class="col-span-3">
                    <label class="block text-sm mb-1 text-slate-600">Cidade</label>
                    <select id="modalCidade" class="w-full border rounded p-2 focus:border-blue-500 outline-none bg-slate-50" disabled>
                        <option value="">Selecione o Estado primeiro...</option>
                    </select>
                </div>
            </div>
            <div>
                <label class="block text-sm mb-1 text-slate-600">Rua/Logradouro</label>
                <input type="text" id="modalRua" placeholder="Av Paulista" class="w-full border rounded p-2 focus:border-blue-500 outline-none">
            </div>
            <button type="button" onclick="buscarCepModal()" class="w-full bg-blue-600 text-white rounded py-3 font-bold hover:bg-blue-700 transition-colors">Pesquisar</button>
        </div>

        <div id="modalResults" class="mt-4 max-h-60 overflow-y-auto space-y-2"></div>
    </div>
</div>

<script>
    // Integração com API do IBGE para listar Cidades
    document.getElementById('modalUf').addEventListener('change', async function() {
        const uf = this.value;
        const cidadeSelect = document.getElementById('modalCidade');
        
        if (!uf) {
            cidadeSelect.innerHTML = '<option value="">Selecione o Estado primeiro...</option>';
            cidadeSelect.disabled = true;
            cidadeSelect.classList.add('bg-slate-50');
            return;
        }

        cidadeSelect.innerHTML = '<option value="">Carregando cidades...</option>';
        cidadeSelect.disabled = true;

        try {
            const res = await fetch(`https://servicodados.ibge.gov.br/api/v1/localidades/estados/${uf}/municipios?orderBy=nome`);
            const cidades = await res.json();
            
            cidadeSelect.innerHTML = '<option value="">Selecione a Cidade...</option>' + 
                cidades.map(c => `<option value="${c.nome}">${c.nome}</option>`).join('');
            
            cidadeSelect.disabled = false;
            cidadeSelect.classList.remove('bg-slate-50');
            cidadeSelect.classList.add('bg-white');
        } catch (error) {
            cidadeSelect.innerHTML = '<option value="">Erro ao carregar</option>';
        }
    });

    // Máscara de Telefone (00) 00000-0000
    document.getElementById('telefone').addEventListener('input', function (e) {
        var x = e.target.value.replace(/\D/g, '').match(/(\d{0,2})(\d{0,5})(\d{0,4})/);
        e.target.value = !x[2] ? x[1] : '(' + x[1] + ') ' + x[2] + (x[3] ? '-' + x[3] : '');
    });

    // Máscara de CEP 00000-000
    document.getElementById('cep').addEventListener('input', function (e) {
        var x = e.target.value.replace(/\D/g, '').match(/(\d{0,5})(\d{0,3})/);
        e.target.value = !x[2] ? x[1] : x[1] + '-' + x[2];
    });

    document.getElementById('cep').addEventListener('blur', buscarCep);

    async function buscarCep() {
        const cepInput = document.getElementById('cep').value;
        if (!cepInput || cepInput.replace(/\D/g, '').length !== 8) return;
        
        try {
            const res = await fetch(`/profile/api/cep?cep=${cepInput}`);
            const data = await res.json();
            
            if (data.erro) {
                showToast(data.mensagem || 'CEP não encontrado', 'error');
                return;
            }
            
            document.getElementById('rua').value = data.logradouro || '';
            document.getElementById('bairro').value = data.bairro || '';
            document.getElementById('cidade').value = data.localidade || '';
            document.getElementById('estado').value = data.uf || '';
        } catch (error) {
            showToast('Erro de conexão ao buscar o CEP. Os campos foram liberados para preenchimento manual.', 'error');
            // Resiliência de rede: Libera campos manuais
            document.getElementById('rua').removeAttribute('readonly');
            document.getElementById('bairro').removeAttribute('readonly');
            document.getElementById('cidade').removeAttribute('readonly');
            document.getElementById('estado').removeAttribute('readonly');
            document.getElementById('rua').classList.remove('bg-slate-50');
            document.getElementById('bairro').classList.remove('bg-slate-50');
            document.getElementById('cidade').classList.remove('bg-slate-50');
            document.getElementById('estado').classList.remove('bg-slate-50');
        }
    }

    function openCepModal() {
        document.getElementById('cepModal').classList.remove('hidden');
    }
    
    function closeCepModal() {
        document.getElementById('cepModal').classList.add('hidden');
        document.getElementById('modalResults').innerHTML = '';
    }

    async function buscarCepModal() {
        const uf = document.getElementById('modalUf').value;
        let cidade = document.getElementById('modalCidade').value;
        const rua = document.getElementById('modalRua').value;
        
        if (!uf || !cidade || !rua) {
            showToast('Preencha UF, Cidade e Rua', 'error');
            return;
        }

        // Auto-correção para Joinvile (erro comum de digitação)
        if (cidade.trim().toLowerCase() === 'joinvile') {
            cidade = 'Joinville';
            document.getElementById('modalCidade').value = 'Joinville';
        }

        const resultsDiv = document.getElementById('modalResults');
        resultsDiv.innerHTML = '<p class="text-center text-slate-500 py-4"><i class="fas fa-spinner fa-spin mr-2"></i>Buscando...</p>';

        try {
            const res = await fetch(`/profile/api/cep/buscar?uf=${uf}&cidade=${cidade}&rua=${rua}`);
            const data = await res.json();
            
            if (data.erro || data.length === 0) {
                resultsDiv.innerHTML = '<p class="text-center text-red-500 py-4">Nenhum endereço encontrado.</p>';
                return;
            }

            resultsDiv.innerHTML = data.map(end => `
                <button type="button" onclick="selecionarEndereco('${end.cep}', '${end.logradouro}', '${end.bairro}', '${end.localidade}', '${end.uf}')" 
                        class="w-full text-left p-3 border border-outline-variant rounded hover:bg-blue-50 focus:bg-blue-50 transition-colors">
                    <p class="font-bold text-blue-700">${end.cep}</p>
                    <p class="text-sm text-slate-600">${end.logradouro} - ${end.bairro}</p>
                    <p class="text-sm text-slate-500">${end.localidade}/${end.uf}</p>
                </button>
            `).join('');

        } catch (error) {
            resultsDiv.innerHTML = '<p class="text-center text-red-500 py-4">Erro de rede. Tente novamente.</p>';
        }
    }

    function selecionarEndereco(cep, rua, bairro, cidade, uf) {
        document.getElementById('cep').value = cep;
        document.getElementById('rua').value = rua;
        document.getElementById('bairro').value = bairro;
        document.getElementById('cidade').value = cidade;
        document.getElementById('estado').value = uf;
        closeCepModal();
    }
</script>
